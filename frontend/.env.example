# Frontend environment variables (Vite reads anything prefixed with VITE_).
#
# Local dev: leave this file alone or omit VITE_API_BASE_URL entirely.
# Vite proxies /api/* to http://127.0.0.1:8000 via vite.config.ts.
#
# Production (Vercel): set this to your Hugging Face Space URL, no trailing slash.
#   Set it in Vercel: Project -> Settings -> Environment Variables.
#   Example shape:
#     VITE_API_BASE_URL=https://your-hf-username-bluealpha-api.hf.space
#
# The browser must be able to reach this URL directly, and the URL must be in
# the backend's CORS_ALLOW_ORIGINS allow-list (or match CORS_ALLOW_ORIGIN_REGEX).

VITE_API_BASE_URL=
